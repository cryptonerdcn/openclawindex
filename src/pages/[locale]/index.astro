---
import HomePage from '../../components/HomePage.astro';
import { assertLocale, buildLocaleHomepageHref, getItemsByKind, getLocaleStaticPaths } from '../../lib/catalog';
import { getMessages } from '../../lib/i18n';
import { LOCALES, type Locale } from '../../types/catalog';
import '../../styles/global.css';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = assertLocale(Astro.params.locale);
const messages = getMessages(locale);
const variants = getItemsByKind('variant');
const services = getItemsByKind('service');
const query = Astro.url.searchParams.toString();

const languageLinks = Object.fromEntries(
  LOCALES.map((option) => [option, buildLocaleHomepageHref(option, query)]),
) as Record<Locale, string>;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={messages.meta.defaultDescription} />
    <title>{messages.home.title}</title>
  </head>
  <body>
    <HomePage locale={locale} messages={messages} variants={variants} services={services} languageLinks={languageLinks} />
  </body>
</html>
